{
  "name": "arc20-conformance-kit",
  "version": "0.1.0",
  "description": "Open-source ARC-20 (IARC20) conformance checks for Aleo Leo programs",
  "type": "module",
  "license": "MIT",
  "bin": {
    "arc20-check": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "dev:web": "concurrently -n api,web -c cyan,magenta \"tsx server/index.ts\" \"vite\"",
    "build:web": "vite build",
    "check": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "aleo",
    "arc-20",
    "iarc20",
    "leo",
    "conformance",
    "token"
  ],
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.0.9"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0"
  }
}
